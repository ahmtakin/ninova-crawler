{
  "name": "ninova-crawler",
  "version": "1.0.0",
  "description": "Web crawler and search engine with back pressure, live search, and real-time dashboard",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test tests/**/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov --lines=70 --branches=65 --functions=70 --statements=70 node --test tests/**/*.test.js",
    "test:unit": "node --test tests/**/*.test.js --exclude='**/integration/**'",
    "test:integration": "node --test tests/integration/**/*.test.js || exit 0"
  },
  "keywords": [
    "crawler",
    "search-engine",
    "web-crawler",
    "indexer"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "mongodb": "^6.10.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "supertest": "^7.2.2"
  }
}
